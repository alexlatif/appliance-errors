# Cloudflare Pages headers — security + cache. Improves the "Server" SEO score
# and Core Web Vitals (immutable hashed assets cache for a year).

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: browser=(), geolocation=()

# Astro hashes asset filenames, so they can cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/logos/*
  Cache-Control: public, max-age=2592000

/images/*
  Cache-Control: public, max-age=2592000

/*.svg
  Cache-Control: public, max-age=2592000

# HTML: short cache so newly published/verified codes go live fast.
/*.html
  Cache-Control: public, max-age=600, must-revalidate

# Feeds + maps: keep fresh.
/sitemap.xml
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
