---
// AdSlot — one place to wire real AdSense ad-unit IDs.
//
// Slot resolution: explicit prop → env (PUBLIC_AD_SLOT_*) → committed
// src/data/ad-slots.json. NO placeholder fallback: an unset placement
// renders NOTHING — broken <ins> units with fake slot ids fire failed ad
// requests on every page and read as a broken site to AdSense review.
// To go live: create the units in AdSense (Ads → By ad unit) and paste the
// slot ids into ad-slots.json (committed; CI builds pick them up).
import adSlots from '../data/ad-slots.json';

export interface Props {
  placement?: 'top' | 'mid' | 'bottom' | 'list';
  slot_id?: string; // explicit override (rarely needed)
  style?: 'leaderboard' | 'rectangle' | 'sidebar' | 'in-article';
  layout?: string;
}
const { placement = 'mid', slot_id, style = 'rectangle', layout } = Astro.props;

const client = import.meta.env.PUBLIC_ADSENSE_CLIENT;
const isDev = import.meta.env.DEV;

const envSlot = {
  top: import.meta.env.PUBLIC_AD_SLOT_TOP,
  mid: import.meta.env.PUBLIC_AD_SLOT_MID,
  bottom: import.meta.env.PUBLIC_AD_SLOT_BOTTOM,
  list: import.meta.env.PUBLIC_AD_SLOT_LIST,
}[placement];
const jsonSlot = (adSlots as Record<string, string>)[placement] || undefined;
const slot = slot_id || envSlot || jsonSlot;

const dims: Record<string, string> = {
  leaderboard: 'min-h-[90px]',
  rectangle: 'min-h-[250px]',
  sidebar: 'min-h-[600px]',
  'in-article': 'min-h-[280px]',
};

const shouldRender = !!client && !!slot;
---
{shouldRender && (
  <div class={`w-full ${dims[style]} my-6 flex justify-center`} data-ad-slot={slot}>
    <ins
      class="adsbygoogle"
      style="display:block; width:100%;"
      data-ad-client={client}
      data-ad-slot={slot}
      data-ad-format={style === 'in-article' ? 'fluid' : 'auto'}
      data-ad-layout={layout}
      data-full-width-responsive="true"
      data-adtest={isDev ? 'on' : undefined}
    />
    <script is:inline>
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
)}
