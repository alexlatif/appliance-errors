---
export interface Props { difficulty: string; }
const { difficulty } = Astro.props;
const cls: Record<string, string> = {
  easy: 'bg-green-50 text-green-700 border-green-200',
  moderate: 'bg-blue-50 text-blue-700 border-blue-200',
  hard: 'bg-orange-50 text-orange-700 border-orange-200',
  pro_only: 'bg-gray-100 text-gray-700 border-gray-300',
};
const label: Record<string, string> = {
  easy: '🔧 Easy DIY', moderate: '🔧🔧 Moderate DIY',
  hard: '🔧🔧🔧 Advanced DIY', pro_only: '👨‍🔧 Call a Pro'
};
---
<span class={`inline-flex items-center gap-1 px-3 py-1 text-sm font-medium rounded-lg border ${cls[difficulty] ?? cls.moderate}`}>
  {label[difficulty] ?? difficulty}
</span>
