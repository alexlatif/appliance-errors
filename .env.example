# Google AdSense publisher ID — exposed to client (PUBLIC_ prefix is required by Astro)
# Leave empty in dev to suppress ad loader.
PUBLIC_ADSENSE_CLIENT=ca-pub-9323140183656137

# AdSense ad-unit slot IDs by placement. Create the units in the AdSense dashboard
# (Ads → By ad unit → Display ads) and paste their data-ad-slot IDs here.
# Until set, AdSlot falls back to placeholders that DO NOT serve real ads.
# Set the same four in Cloudflare Pages → Settings → Environment variables for prod.
PUBLIC_AD_SLOT_TOP=
PUBLIC_AD_SLOT_MID=
PUBLIC_AD_SLOT_BOTTOM=
PUBLIC_AD_SLOT_LIST=
