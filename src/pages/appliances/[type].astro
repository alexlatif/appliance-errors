---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeverityBadge from '../../components/SeverityBadge.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import AdSlot from '../../components/AdSlot.astro';
import {
  brands, applianceTypes, getApplianceType,
  getCodesByBrandAndAppliance, getBrand
} from '../../utils/data';

export async function getStaticPaths() {
  return applianceTypes.map(a => ({ params: { type: a.slug } }));
}

const { type: typeSlug } = Astro.params;
const appType = getApplianceType(typeSlug!)!;

// All brands that have this appliance type
const brandsWithType = brands.filter(b => b.appliances.includes(typeSlug!));
const allCodes = brandsWithType.flatMap(b => getCodesByBrandAndAppliance(b.slug, typeSlug!));

const title = `${appType.name} Error Codes — All Brands | ApplianceErrors.com`;
const description = `${appType.name} error codes for every major brand. ${allCodes.length}+ codes from Samsung, LG, Whirlpool, GE, Bosch and more. Plain-English meanings and step-by-step fixes.`;
// Short intro blurbs per appliance type for content depth
const INTROS: Record<string,string> = {
  'range-hood': 'Range hood error codes appear on smart and connected models — covering fan motor faults, communication errors, heat sensor trips, and light circuit failures. Broan-NuTone, the largest US range hood manufacturer, uses E-codes on Elite and connected series hoods. Most budget range hood failures (fan not running, lights out) have no display code but follow a standard diagnostic sequence: check the circuit breaker, clean the grease filters, test the motor windings.',
  washer: 'Washing machine error codes point to specific subsystems — water inlet valves, drain pumps, door latches, motor drivers, and control boards. Understanding the code tells you whether the repair is a $15 part or a $250 service call.',
  dryer: 'Dryer error codes most commonly indicate airflow restrictions, heating element failures, or thermistor faults. Many codes — especially LG D-codes and Samsung DC codes — clear with basic maintenance like duct cleaning.',
  dishwasher: 'Dishwasher error codes cover water supply (fill errors), drainage (pump and drain valve), door latch, water heating, and control board failures. Many error codes resolve with a simple drain filter clean.',
  refrigerator: 'Refrigerator error codes indicate faults in the sealed refrigerant system, fan motors, ice maker, defrost heater, and temperature sensors. Most display-code failures are sensor or fan related, not compressor related.',
  oven: 'Oven error codes on modern ranges are generated by the Electronic Range Control (ERC) board. F-codes dominate Whirlpool-platform brands (Whirlpool, Maytag, KitchenAid, Amana); E-codes appear on Samsung, LG, and Bosch.',
  microwave: 'Microwave error codes most often indicate keypad membrane failures (SE, F-3) or internal sensor faults. Due to high-voltage capacitor hazards, internal microwave repairs should be left to professionals.',
};
const intro = INTROS[typeSlug!] ?? '';
---

<BaseLayout {title} {description}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <BreadcrumbNav items={[
      { label: 'Home', href: '/' },
      { label: `${appType.name} Error Codes` }
    ]} />

    <div class="flex items-center gap-4 mb-6">
      <span class="text-6xl">{appType.icon}</span>
      <div>
        <h1 class="text-3xl font-bold text-gray-900">{appType.name} Error Codes</h1>
        <p class="text-gray-600 mt-1">
          {allCodes.length} error codes across {brandsWithType.length} {brandsWithType.length === 1 ? 'brand' : 'brands'}
        </p>
      </div>
    </div>

    {intro && (
      <p class="text-gray-700 leading-relaxed mb-8 max-w-3xl">{intro}</p>
    )}

    <AdSlot placement="list" style="leaderboard" />

    <!-- Brand cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {brandsWithType.map(brand => {
        const codes = getCodesByBrandAndAppliance(brand.slug, typeSlug!);
        const highSeverity = codes.filter(c => c.severity === 'high' || c.severity === 'critical');
        return (
          <a href={`/brands/${brand.slug}/${typeSlug}/`}
             class="group border border-gray-200 rounded-xl p-5 hover:border-brand-400 hover:shadow-lg transition-all">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg flex items-center justify-center text-white font-bold flex-shrink-0"
                   style={`background-color: ${brand.logo_color}`}>
                {brand.name[0]}
              </div>
              <div>
                <div class="font-bold text-gray-900 group-hover:text-brand-600">{brand.name}</div>
                <div class="text-xs text-gray-500">{codes.length} error codes</div>
              </div>
            </div>
            <div class="space-y-1">
              {codes.slice(0, 4).map(code => (
                <div class="flex items-center gap-2 text-sm">
                  <span class="font-mono font-bold text-brand-600 w-12 flex-shrink-0">{code.code}</span>
                  <span class="text-gray-600 truncate">{code.meaning}</span>
                </div>
              ))}
              {codes.length > 4 && (
                <div class="text-sm text-brand-500 mt-1">+{codes.length - 4} more codes →</div>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
