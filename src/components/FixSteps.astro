---
import type { FixStep } from '../utils/types';
export interface Props { steps: FixStep[]; }
const { steps } = Astro.props;
---
<ol class="space-y-6">
  {steps.map((step, i) => (
    <li class="flex gap-4">
      <div class="flex-shrink-0">
        <div class="w-9 h-9 bg-brand-600 text-white rounded-full flex items-center justify-center font-bold text-sm">
          {i + 1}
        </div>
        {i < steps.length - 1 && (
          <div class="w-px bg-gray-200 mx-auto mt-1" style="height: calc(100% - 36px)"></div>
        )}
      </div>
      <div class="flex-1 pb-2">
        <h3 class="font-semibold text-gray-900 mb-1">{step.title}</h3>
        <p class="text-gray-700 leading-relaxed">{step.description}</p>
        {step.parts && step.parts.length > 0 && (
          <div class="mt-2 flex flex-wrap gap-2">
            {step.parts.map(part => (
              <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded border border-gray-200">
                🔩 {part}
              </span>
            ))}
          </div>
        )}
        {step.warning && (
          <div class="mt-2 bg-yellow-50 border border-yellow-200 rounded px-3 py-2 text-sm text-yellow-800">
            ⚠️ {step.warning}
          </div>
        )}
      </div>
    </li>
  ))}
</ol>
