---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SeverityBadge from '../../../../components/SeverityBadge.astro';
import DifficultyBadge from '../../../../components/DifficultyBadge.astro';
import BreadcrumbNav from '../../../../components/BreadcrumbNav.astro';
import CausesList from '../../../../components/CausesList.astro';
import FixSteps from '../../../../components/FixSteps.astro';
import AdSlot from '../../../../components/AdSlot.astro';
import ReviewedBy from '../../../../components/ReviewedBy.astro';
import FeedbackWidget from '../../../../components/FeedbackWidget.astro';
import {
  brands, applianceTypes, errorCodes,
  getBrand, getApplianceType, getCode, getRelatedCodes, getCrossBrandCodes,
  getCodesByBrandAndAppliance, slugifyCode
} from '../../../../utils/data';
import { faqSchema, howToSchema, breadcrumbSchema, articleSchema, errorCodeFaqs } from '../../../../utils/schema';
import { verifiedDate, verifiedDateHuman } from '../../../../utils/freshness';
import { sourcesForBrand } from '../../../../utils/sources';
import { focus } from '../../../../utils/focus';

// Short appliance names for <title> (saves chars vs "Washing Machine", "Refrigerator")
const APP_SHORT: Record<string,string> = {
  washer: 'Washer', dryer: 'Dryer', dishwasher: 'Dishwasher',
  refrigerator: 'Refrigerator', oven: 'Oven', microwave: 'Microwave',
  'air-conditioner': 'AC', freezer: 'Freezer', 'range-hood': 'Range Hood',
};
// Shorter names for title tags (keep ≤65 chars total)
const BRAND_SHORT: Record<string,string> = {
  'ge': 'GE', 'broan': 'Broan', 'fisher-paykel': 'Fisher & Paykel',
  'speedqueen': 'Speed Queen',
};

export async function getStaticPaths() {
  return errorCodes.map(c => ({
    params: {
      brand: c.brand,
      appliance: c.appliance,
      code: slugifyCode(c.code),
    },
    props: { errorCode: c },
  }));
}

const { brand: brandSlug, appliance: appSlug } = Astro.params;
const { errorCode } = Astro.props;

const brand = getBrand(brandSlug!)!;
const appType = getApplianceType(appSlug!);
const relatedCodes = getRelatedCodes(errorCode);
const crossBrandCodes = getCrossBrandCodes(errorCode.code, brandSlug!).slice(0, 4);

const relatedIds = new Set([errorCode.id, ...relatedCodes.map(c => c.id)]);
const siblingCodes = getCodesByBrandAndAppliance(brandSlug!, appSlug!)
  .filter(c => !relatedIds.has(c.id))
  .slice(0, 6);

const codeKey = errorCode.code.toUpperCase().replace(/[-\s]/g, '');
const crossBrandPageExists = errorCodes.filter(c => c.code.toUpperCase().replace(/[-\s]/g, '') === codeKey).length >= 2;
const crossBrandPageUrl = `/error/${codeKey.toLowerCase()}/`;

const brandSources = sourcesForBrand(brandSlug!);
const lastVerified = verifiedDate(errorCode);
const lastVerifiedHuman = verifiedDateHuman(errorCode);
const appName = appType?.name ?? appSlug!;
// Short names for titles — "Washing Machine"→"Washer", keeps <title> ≤65 chars
const appShort = (APP_SHORT as Record<string,string>)[appSlug!] ?? appName;
const brandName = brand.name;
const brandShort = BRAND_SHORT[brandSlug!] ?? brandName;

// Part links — PartSelect and RepairClinic search URLs
const partSelectUrl = `https://www.partselect.com/PartSearchResults.aspx?SearchTerm=${encodeURIComponent(brandName + ' ' + appShort + ' ' + errorCode.code)}`;
const repairClinicUrl = `https://www.repairclinic.com/Shop-For-Parts/a/~/${encodeURIComponent(brandName + '-' + appShort)}`;

// Code-first title — ≤65 chars. "D80 Error Code — LG Dryer Fix | ApplianceErrors.com" = 51 chars
// Lead with brand + appliance + code to match the dominant "<brand> <appliance> <code>"
// search pattern; no site-name suffix (SERP shows the domain) to stay under ~60 chars.
const title = `${brandShort} ${appShort} ${errorCode.code} Error — Causes & Fix`;

// Description ≤155 chars — meaning truncated, punchy suffix
const meaningTrunc = errorCode.meaning.length > 90
  ? errorCode.meaning.slice(0, 87) + '…'
  : errorCode.meaning;
const description = `${meaningTrunc}. DIY fix for ${brandName} ${appShort} error ${errorCode.code}: causes, steps & parts.`;

const schemas = [
  faqSchema(errorCode, brandName, appName),
  howToSchema(errorCode, brandName, appName),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Brands', url: '/brands/' },
    { name: brandName, url: `/brands/${brandSlug}/` },
    { name: `${appName} Errors`, url: `/brands/${brandSlug}/${appSlug}/` },
    { name: `Error ${errorCode.code}`, url: `/brands/${brandSlug}/${appSlug}/${slugifyCode(errorCode.code)}/` },
  ]),
  articleSchema(errorCode, brandName, appName, lastVerified),
];

const severityColors: Record<string, string> = {
  low: 'border-green-200 bg-green-50',
  medium: 'border-yellow-200 bg-yellow-50',
  high: 'border-red-200 bg-red-50',
  critical: 'border-red-900 bg-red-950',
};
const costSaving = errorCode.pro_cost_lo - errorCode.cost_lo;
---

<BaseLayout {title} {description} {schemas} ogImage={`/images/og/${errorCode.id}.png`} noindex={focus.isPageNoindex(errorCode.id)}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <BreadcrumbNav items={[
      { label: 'Home', href: '/' },
      { label: 'Brands', href: '/brands/' },
      { label: brandName, href: `/brands/${brandSlug}/` },
      { label: `${appName} Errors`, href: `/brands/${brandSlug}/${appSlug}/` },
      { label: `Error ${errorCode.code}` }
    ]} />

    <!-- H1 + Quick status -->
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 leading-tight mb-4">
      {brandName} {appName} Error Code <span class="text-brand-600 font-mono">{errorCode.code}</span>
    </h1>

    <ReviewedBy verifiedDate={lastVerifiedHuman} />

    <!-- Quick answer box -->
    <div class={`rounded-xl border-2 p-5 mb-8 ${severityColors[errorCode.severity]}`}>
      <div class="flex flex-wrap gap-3 mb-3">
        <SeverityBadge severity={errorCode.severity} large />
        <DifficultyBadge difficulty={errorCode.diy_difficulty} />
        {errorCode.aliases.length > 0 && (
          <span class="text-sm text-gray-500 pt-1">
            Also shown as: <strong>{errorCode.aliases.join(', ')}</strong>
          </span>
        )}
      </div>
      <p class="text-gray-800 text-lg font-medium">{errorCode.meaning}</p>
      <div class="mt-3 flex flex-wrap gap-6 text-sm text-gray-600">
        <span>💰 DIY cost: <strong>${errorCode.cost_lo}–${errorCode.cost_hi}</strong></span>
        <span>👨‍🔧 Pro cost: <strong>${errorCode.pro_cost_lo}–${errorCode.pro_cost_hi}</strong></span>
        {costSaving > 50 && (
          <span class="text-green-700 font-medium">Save ${costSaving}+ by doing it yourself</span>
        )}
      </div>
    </div>

    <!-- Display illustration (image SEO) -->
    <figure class="mb-8">
      <img src={`/images/codes/${errorCode.id}.svg`}
           alt={`${brandName} ${appName} error code ${errorCode.code} on the display panel`}
           width="800" height="450" loading="lazy"
           class="w-full max-w-xl mx-auto rounded-xl border border-gray-200" />
      <figcaption class="text-center text-xs text-gray-400 mt-2">
        How the {errorCode.code} code appears on a {brandName} {appName.toLowerCase()} display
      </figcaption>
    </figure>

    <!-- Top ad -->
    <AdSlot placement="top" style="leaderboard" />

    <!-- Table of contents -->
    <nav class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-8">
      <p class="font-semibold text-gray-700 mb-2 text-sm">ON THIS PAGE</p>
      <ol class="grid sm:grid-cols-2 gap-1 text-sm">
        <li><a href="#what-it-means" class="text-brand-600 hover:underline">What this error means</a></li>
        <li><a href="#causes" class="text-brand-600 hover:underline">Common causes</a></li>
        <li><a href="#how-to-fix" class="text-brand-600 hover:underline">Step-by-step fix</a></li>
        <li><a href="#reset" class="text-brand-600 hover:underline">How to reset</a></li>
        <li><a href="#when-to-call-pro" class="text-brand-600 hover:underline">When to call a pro</a></li>
        <li><a href="#faqs" class="text-brand-600 hover:underline">FAQs</a></li>
      </ol>
    </nav>

    <!-- What it means -->
    <section id="what-it-means" class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">
        What Does Error Code {errorCode.code} Mean on a {brandName} {appName}?
      </h2>
      <p class="text-gray-700 leading-relaxed text-lg">{errorCode.meaning}.</p>
      <p class="text-gray-600 mt-3 leading-relaxed">{errorCode.detail}</p>

      {errorCode.models_affected && (
        <div class="mt-4 bg-blue-50 border border-blue-200 rounded-lg px-4 py-3 text-sm text-blue-800">
          <strong>Models affected:</strong> {errorCode.models_affected}
        </div>
      )}
    </section>

    <!-- Causes -->
    <section id="causes" class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">What Causes Error Code {errorCode.code}?</h2>
      <p class="text-gray-600 mb-5">
        Here are the most common causes in order of frequency. Start with the most likely cause before moving to the next:
      </p>
      <CausesList causes={errorCode.causes} />
    </section>

    <!-- Mid-content ad -->
    <AdSlot placement="mid" style="rectangle" />

    <!-- Fix steps -->
    <section id="how-to-fix" class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">
        How to Fix {brandName} {appName} Error Code {errorCode.code}
      </h2>
      <div class="flex flex-wrap gap-3 mb-5">
        <DifficultyBadge difficulty={errorCode.diy_difficulty} />
        <span class="text-sm text-gray-500 pt-1">
          Est. time: {errorCode.diy_difficulty === 'easy' ? '10–20 min' : errorCode.diy_difficulty === 'moderate' ? '30–60 min' : '1–3 hours'}
        </span>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 mb-6 text-sm text-amber-800">
        ⚡ <strong>Safety first:</strong> Unplug the appliance before opening any panels or touching internal components.
      </div>

      <FixSteps steps={errorCode.fixes} />
    </section>

    <!-- Reset instructions -->
    <section id="reset" class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">
        How to Reset Error Code {errorCode.code}
      </h2>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-5">
        <p class="text-gray-700 leading-relaxed">{errorCode.reset_instructions}</p>
      </div>
      <p class="text-sm text-gray-500 mt-3">
        Note: If the error returns after resetting, the underlying issue has not been resolved. Work through the fix steps above.
      </p>
    </section>

    <!-- Feedback: did this fix work? -->
    <FeedbackWidget codeId={errorCode.id} />

    <!-- When to call a pro -->
    <section id="when-to-call-pro" class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">When to Call a Professional</h2>
      <div class="border border-gray-200 rounded-xl p-5">
        <p class="text-gray-700 leading-relaxed">{errorCode.when_to_call_pro}</p>
        <div class="mt-4 text-sm text-gray-500">
          Average professional repair cost for this issue: <strong>${errorCode.pro_cost_lo}–${errorCode.pro_cost_hi}</strong>
        </div>
      </div>
    </section>

    <!-- Related codes -->
    {relatedCodes.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Related Error Codes</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {relatedCodes.map(rc => (
            <a href={`/brands/${rc.brand}/${rc.appliance}/${slugifyCode(rc.code)}/`}
               class="flex gap-3 items-start p-4 border border-gray-200 rounded-xl hover:border-brand-400 hover:shadow-md transition-all">
              <span class="font-bold text-brand-600 font-mono w-12 flex-shrink-0">{rc.code}</span>
              <div>
                <div class="font-medium text-gray-800">{rc.meaning}</div>
                <SeverityBadge severity={rc.severity} />
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Cross-brand comparison -->
    {crossBrandCodes.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Same Code on Other Brands</h2>
        <p class="text-gray-500 text-sm mb-4">
          Error code <strong>{errorCode.code}</strong> appears on these other brands too.
          {crossBrandPageExists && (
            <a href={crossBrandPageUrl} class="text-brand-600 hover:underline ml-1">See every brand that shows {errorCode.code} →</a>
          )}
        </p>
        <div class="grid sm:grid-cols-2 gap-3">
          {crossBrandCodes.map(rc => {
            const rcBrand = getBrand(rc.brand);
            const rcApp = getApplianceType(rc.appliance);
            return (
              <a href={`/brands/${rc.brand}/${rc.appliance}/${slugifyCode(rc.code)}/`}
                 class="flex items-start gap-3 p-4 border border-gray-200 rounded-xl hover:border-brand-400 hover:shadow-md transition-all group">
                <div class="w-14 h-10 flex items-center justify-center rounded-lg overflow-hidden border border-gray-100 bg-white p-1 flex-shrink-0">
                  <img src={`/logos/${rc.brand}.svg`} alt={`${rcBrand?.name} logo`} class="h-8 w-auto max-w-[52px] object-contain"/>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-semibold text-gray-800 group-hover:text-brand-600">
                    {rcBrand?.name} {rcApp?.name} {rc.code}
                  </div>
                  <div class="text-sm text-gray-500 truncate">{rc.meaning}</div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Part finder links -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">Find Replacement Parts</h2>
      <p class="text-gray-600 text-sm mb-4">
        Use these links to find the exact replacement parts for your {brandName} {appName}:
      </p>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href={partSelectUrl} target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-3 p-4 border-2 border-blue-200 bg-blue-50 rounded-xl hover:border-blue-400 hover:shadow-md transition-all group">
          <div class="w-10 h-10 bg-blue-600 text-white rounded-lg flex items-center justify-center flex-shrink-0 text-lg">🔩</div>
          <div>
            <div class="font-semibold text-blue-900 group-hover:text-blue-700">Search PartSelect</div>
            <div class="text-xs text-blue-600">{brandName} {appName} repair parts</div>
          </div>
          <svg class="w-4 h-4 text-blue-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
        <a href={`https://www.repairclinic.com/Shop-For-Parts/a/~/${encodeURIComponent(brandName + '-' + appName)}`}
           target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-3 p-4 border-2 border-orange-200 bg-orange-50 rounded-xl hover:border-orange-400 hover:shadow-md transition-all group">
          <div class="w-10 h-10 bg-orange-500 text-white rounded-lg flex items-center justify-center flex-shrink-0 text-lg">🔧</div>
          <div>
            <div class="font-semibold text-orange-900 group-hover:text-orange-700">Search RepairClinic</div>
            <div class="text-xs text-orange-600">Step-by-step video guides</div>
          </div>
          <svg class="w-4 h-4 text-orange-400 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>
      <p class="text-xs text-gray-400 mt-2">External links — ApplianceErrors.com is not affiliated with these retailers.</p>
    </section>

    <!-- More codes from this brand+appliance (internal-link density) -->
    {siblingCodes.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">More {brandName} {appName} Error Codes</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          {siblingCodes.map(sc => (
            <a href={`/brands/${sc.brand}/${sc.appliance}/${slugifyCode(sc.code)}/`}
               class="px-3 py-2 border border-gray-200 rounded-lg hover:border-brand-400 text-sm transition-all">
              <span class="font-bold text-brand-600 font-mono">{sc.code}</span>
              <span class="text-gray-500 block truncate text-xs">{sc.meaning}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- FAQs -->
    <section id="faqs" class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {errorCodeFaqs(errorCode, brandName, appName).map(faq => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="px-5 py-4 cursor-pointer font-semibold text-gray-800 hover:bg-gray-50 list-none flex justify-between items-center">
              {faq.q}
              <span class="text-gray-400 text-xl group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="px-5 py-4 text-gray-700 border-t border-gray-100">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- Sources & references (E-E-A-T) -->
    <section class="mb-10">
      <h2 class="text-lg font-bold text-gray-900 mb-2">Sources & References</h2>
      <ul class="text-sm text-gray-600 space-y-1">
        {brandSources.map(s => (
          <li>
            • <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:underline">{s.name}</a>
            <span class="text-gray-400"> — official manufacturer documentation</span>
          </li>
        ))}
        <li>• <a href="/editorial-policy/" class="text-brand-600 hover:underline">Our editorial &amp; verification policy</a></li>
      </ul>
      <p class="text-xs text-gray-400 mt-2">
        Content verified against manufacturer service documentation. Last verified: {lastVerifiedHuman}.
      </p>
    </section>

    <!-- Bottom ad -->
    <AdSlot placement="bottom" style="rectangle" />

    <!-- Back links -->
    <div class="flex flex-wrap gap-3 mt-6 pt-6 border-t border-gray-200">
      <a href={`/brands/${brandSlug}/${appSlug}/`}
         class="text-sm text-brand-600 hover:underline">
        ← All {brandName} {appName} Error Codes
      </a>
      <a href={`/brands/${brandSlug}/`}
         class="text-sm text-brand-600 hover:underline">
        ← All {brandName} Error Codes
      </a>
    </div>
  </div>
</BaseLayout>
