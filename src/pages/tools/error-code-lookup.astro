---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import { brands, applianceTypes, totalCodeCount } from '../../utils/data';
import { breadcrumbSchema } from '../../utils/schema';

const title = `Appliance Error Code Lookup Tool — ${totalCodeCount()}+ Codes | ApplianceErrors.com`;
const description = `Free interactive error code lookup. Filter ${totalCodeCount()}+ appliance error codes by brand, appliance type, or code. Instant plain-English meanings and fix guides.`;

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Tools', url: '/tools/error-code-lookup/' },
    { name: 'Error Code Lookup', url: '/tools/error-code-lookup/' },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Appliance Error Code Lookup",
    "url": "https://applianceerrors.com/tools/error-code-lookup/",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": description,
  },
];
---

<BaseLayout {title} {description} {schemas}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <BreadcrumbNav items={[
      { label: 'Home', href: '/' },
      { label: 'Error Code Lookup Tool' }
    ]} />

    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Error Code Lookup Tool</h1>
    <p class="text-gray-600 mb-8 max-w-2xl">
      Filter {totalCodeCount()}+ error codes by brand, appliance, or the code on your display.
      Every result links to a full plain-English fix guide.
    </p>

    <!-- Filters -->
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-5 mb-6">
      <div class="grid sm:grid-cols-3 gap-4">
        <div>
          <label for="lf-brand" class="block text-sm font-semibold text-gray-700 mb-1">Brand</label>
          <select id="lf-brand" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-white text-gray-800 focus:outline-none focus:border-brand-500">
            <option value="">Any brand</option>
            {brands.map(b => <option value={b.slug}>{b.name}</option>)}
          </select>
        </div>
        <div>
          <label for="lf-appliance" class="block text-sm font-semibold text-gray-700 mb-1">Appliance</label>
          <select id="lf-appliance" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-white text-gray-800 focus:outline-none focus:border-brand-500">
            <option value="">Any appliance</option>
            {applianceTypes.map(a => <option value={a.slug}>{a.name}</option>)}
          </select>
        </div>
        <div>
          <label for="lf-code" class="block text-sm font-semibold text-gray-700 mb-1">Error code</label>
          <input id="lf-code" type="search" placeholder="e.g. 4C, F21, E15…" autocomplete="off" autocorrect="off"
                 class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-white text-gray-800 focus:outline-none focus:border-brand-500" />
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="lf-summary" class="text-sm text-gray-500 mb-3"></div>
    <div id="lf-results" class="space-y-2"></div>
    <div id="lf-empty" class="hidden text-center py-12 text-gray-500">
      <p class="text-lg mb-2">No codes match those filters.</p>
      <p class="text-sm">Try clearing the code field, or <a href="/brands/" class="text-brand-600 hover:underline">browse by brand</a> —
        your code may be listed under an alias.</p>
    </div>
  </div>

  <script>
    type Entry = { b: string; bs: string; a: string; as: string; c: string; m: string; sev: string; u: string };
    let index: Entry[] = [];
    const sevBadge: Record<string, string> = {
      low: '<span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700">Low</span>',
      medium: '<span class="text-xs px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-700">Medium</span>',
      high: '<span class="text-xs px-2 py-0.5 rounded-full bg-red-100 text-red-700">High</span>',
      critical: '<span class="text-xs px-2 py-0.5 rounded-full bg-red-900 text-white">Critical</span>',
    };
    const norm = (s: string) => s.toLowerCase().replace(/[-_\s]/g, '');

    function render() {
      const brand = (document.getElementById('lf-brand') as HTMLSelectElement).value;
      const appliance = (document.getElementById('lf-appliance') as HTMLSelectElement).value;
      const q = norm((document.getElementById('lf-code') as HTMLInputElement).value);
      const results = document.getElementById('lf-results')!;
      const empty = document.getElementById('lf-empty')!;
      const summary = document.getElementById('lf-summary')!;

      let out = index.filter(e =>
        (!brand || e.bs === brand) &&
        (!appliance || e.as === appliance) &&
        (!q || norm(e.c).includes(q) || norm(e.m).includes(q))
      );
      if (q) {
        out.sort((a, b) => {
          const sa = norm(a.c) === q ? 0 : norm(a.c).startsWith(q) ? 1 : 2;
          const sb = norm(b.c) === q ? 0 : norm(b.c).startsWith(q) ? 1 : 2;
          return sa - sb;
        });
      }
      const shown = out.slice(0, 60);
      summary.textContent = out.length
        ? `${out.length} code${out.length > 1 ? 's' : ''} found${out.length > 60 ? ' (showing first 60 — narrow your filters)' : ''}`
        : '';
      results.innerHTML = shown.map(e => `
        <a href="${e.u}" class="flex items-center gap-4 p-4 border border-gray-200 rounded-xl hover:border-brand-400 hover:shadow-md transition-all">
          <div class="w-14 h-10 bg-brand-600 text-white rounded-lg flex items-center justify-center font-bold font-mono text-sm flex-shrink-0">${e.c}</div>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-gray-800">${e.b} ${e.a}</div>
            <div class="text-sm text-gray-500 truncate">${e.m}</div>
          </div>
          ${sevBadge[e.sev] ?? ''}
        </a>`).join('');
      empty.classList.toggle('hidden', out.length > 0);
      results.classList.toggle('hidden', out.length === 0);
    }

    async function init() {
      try { index = await fetch('/search-index.json').then(r => r.json()); } catch { return; }
      render();
      document.getElementById('lf-brand')!.addEventListener('change', render);
      document.getElementById('lf-appliance')!.addEventListener('change', render);
      document.getElementById('lf-code')!.addEventListener('input', render);
    }
    document.addEventListener('DOMContentLoaded', init);
  </script>
</BaseLayout>
