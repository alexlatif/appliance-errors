---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBox from '../components/SearchBox.astro';
import AdSlot from '../components/AdSlot.astro';
import { brands, applianceTypes, totalCodeCount } from '../utils/data';
import { webSiteSchema } from '../utils/schema';

const tc = totalCodeCount();
// ≤65 chars
const title = 'Appliance Error Code Lookup & Fixes | ApplianceErrors.com';
// ≤155 chars
const description = `${tc}+ appliance error codes for Samsung, LG, Whirlpool, GE, Bosch & more. What it means, why it happens, and exactly how to fix it — free.`;
const schemas = [webSiteSchema(tc)];  // Organization injected sitewide by BaseLayout
---

<BaseLayout {title} {description} {schemas}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-700 to-brand-900 text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-4 leading-tight">
        What Does Your Appliance<br class="hidden md:block"/> Error Code Mean?
      </h1>
      <p class="text-blue-100 text-lg mb-8 max-w-xl mx-auto">
        {totalCodeCount()}+ error codes for every major brand. Plain English. Step-by-step fixes. Free.
      </p>

      <!-- Search -->
      <SearchBox />
      <p class="text-blue-200 text-sm mt-3">Or <a href="/brands/" class="underline hover:text-white">browse by brand</a> · <a href="/appliances/washer/" class="underline hover:text-white">browse by appliance</a></p>
    </div>
  </section>

  <!-- Brand grid -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">
      Browse by Brand
      <span class="ml-2 text-base font-normal text-gray-500">({brands.length} brands)</span>
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      {brands.map(brand => (
        <a href={`/brands/${brand.slug}/`}
           class="group border border-gray-200 rounded-xl p-4 hover:border-brand-400 hover:shadow-md transition-all text-center">
          <div class="h-12 flex items-center justify-center mb-3">
            <img src={`/logos/${brand.slug}.svg`} alt={`${brand.name} logo`}
                 class="h-10 w-auto max-w-[120px] object-contain"
                 onerror={`this.style.display='none';this.nextSibling.style.display='flex'`} loading="lazy"/>
            <div class="w-10 h-10 rounded-full hidden items-center justify-center text-white text-lg font-bold"
                 style={`background-color: ${brand.logo_color}`}>{brand.name[0]}</div>
          </div>
          <div class="font-semibold text-gray-800 group-hover:text-brand-600 text-sm">{brand.name}</div>
          <div class="text-xs text-gray-500 mt-1">{brand.appliances.length} appliances</div>
        </a>
      ))}
    </div>
  </section>

  <!-- Appliance type grid -->
  <section class="bg-gray-50 py-12">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Browse by Appliance</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {applianceTypes.map(type => (
          <a href={`/appliances/${type.slug}/`}
             class="group bg-white border border-gray-200 rounded-xl p-4 hover:border-brand-400 hover:shadow-md transition-all text-center">
            <div class="text-3xl mb-2">{type.icon}</div>
            <div class="font-semibold text-gray-800 group-hover:text-brand-600 text-sm">{type.name}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Popular codes -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Most Searched Error Codes</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        { brand: 'lg', appliance: 'dryer', code: 'd80', label: 'LG Dryer D80', desc: 'Duct blockage detected — 80% blocked' },
        { brand: 'samsung', appliance: 'dishwasher', code: 'lc', label: 'Samsung Dishwasher LC', desc: 'Leak sensor activated' },
        { brand: 'lg', appliance: 'dryer', code: 'd90', label: 'LG Dryer D90', desc: 'Duct blockage detected — 90% blocked' },
        { brand: 'whirlpool', appliance: 'dryer', code: 'f01', label: 'Whirlpool Dryer F01', desc: 'Main control board failure' },
        { brand: 'bosch', appliance: 'dishwasher', code: 'e15', label: 'Bosch Dishwasher E15', desc: 'Leak protection activated' },
        { brand: 'samsung', appliance: 'refrigerator', code: '22e', label: 'Samsung Fridge 22E', desc: 'Ice maker fan motor error' },
        { brand: 'whirlpool', appliance: 'washer', code: 'f8e1', label: 'Whirlpool Washer F8E1', desc: 'Low water fill detected' },
        { brand: 'lg', appliance: 'washer', code: 'oe', label: 'LG Washer OE', desc: 'Drainage failure' },
        { brand: 'samsung', appliance: 'washer', code: '4c', label: 'Samsung Washer 4C', desc: 'Water supply issue' },
      ].map(item => (
        <a href={`/brands/${item.brand}/${item.appliance}/${item.code}/`}
           class="group flex items-start gap-3 p-4 border border-gray-200 rounded-xl hover:border-brand-400 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-brand-100 text-brand-700 rounded-lg flex items-center justify-center font-bold text-sm flex-shrink-0 group-hover:bg-brand-600 group-hover:text-white transition-colors">
            {item.code.toUpperCase()}
          </div>
          <div>
            <div class="font-semibold text-gray-800 group-hover:text-brand-600">{item.label}</div>
            <div class="text-sm text-gray-500">{item.desc}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-brand-700 text-white py-8">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div><div class="text-3xl font-bold">{tc}+</div><div class="text-blue-200 text-sm mt-1">Error Codes</div></div>
        <div><div class="text-3xl font-bold">{brands.length}</div><div class="text-blue-200 text-sm mt-1">Brands Covered</div></div>
        <div><div class="text-3xl font-bold">6</div><div class="text-blue-200 text-sm mt-1">Appliance Types</div></div>
        <div><div class="text-3xl font-bold">Free</div><div class="text-blue-200 text-sm mt-1">Always</div></div>
      </div>
    </div>
  </section>

  <!-- Browse other ways -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <AdSlot placement="list" style="leaderboard" />
    <h2 class="text-2xl font-bold text-gray-900 mb-6 mt-4">More Ways to Troubleshoot</h2>
    <div class="grid sm:grid-cols-3 gap-4">
      <a href="/symptoms/" class="p-5 border border-gray-200 rounded-xl hover:border-brand-400 hover:shadow-md transition-all">
        <div class="text-3xl mb-2">🩺</div>
        <div class="font-bold text-gray-900 mb-1">Troubleshoot by Symptom</div>
        <p class="text-sm text-gray-500">No code on the display? Start from what the appliance is doing — won't drain, not heating, leaking…</p>
      </a>
      <a href="/costs/" class="p-5 border border-gray-200 rounded-xl hover:border-brand-400 hover:shadow-md transition-all">
        <div class="text-3xl mb-2">💰</div>
        <div class="font-bold text-gray-900 mb-1">Repair Cost Guides</div>
        <p class="text-sm text-gray-500">DIY vs professional cost by appliance and problem type, computed from our code database.</p>
      </a>
      <a href="/models/" class="p-5 border border-gray-200 rounded-xl hover:border-brand-400 hover:shadow-md transition-all">
        <div class="text-3xl mb-2">🏷️</div>
        <div class="font-bold text-gray-900 mb-1">Codes by Model</div>
        <p class="text-sm text-gray-500">Find the most common error codes for your exact model number.</p>
      </a>
    </div>
  </section>

  <!-- How it works / intro content -->
  <section class="max-w-4xl mx-auto px-4 py-14">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">What Your Appliance Error Code Is Telling You</h2>
    <p class="text-gray-700 leading-relaxed mb-4">
      Modern appliances have built-in self-diagnostic systems. When something goes wrong — a clogged drain, a failed sensor, a faulty motor — the machine stops running and displays an error code on the screen. These codes are not random: each one points to a specific subsystem that has failed or detected a problem.
    </p>
    <p class="text-gray-700 leading-relaxed mb-4">
      The challenge is that each manufacturer uses its own code system. <strong>Samsung uses number codes like 4C, 5E, and 22E</strong>. <strong>LG uses letters like OE, LE, and DE</strong>. <strong>Whirlpool uses F-codes like F8E1 and F1E2</strong>. GE uses short codes like F2 and F3. Even two appliances from the same brand can use completely different codes depending on the model year. This makes looking up codes confusing and time-consuming.
    </p>
    <p class="text-gray-700 leading-relaxed mb-6">
      ApplianceErrors.com aggregates manufacturer service documentation across every major brand and translates it into plain English. Every error code page explains what triggered the code, lists the most common causes in order of likelihood, provides a step-by-step DIY repair guide, and tells you when the repair genuinely requires a professional.
    </p>

    <div class="grid sm:grid-cols-3 gap-4 mb-8">
      {[
        { icon: '🔍', title: 'Find your code', body: 'Search by code, brand, or appliance type. Start with just the letters — e.g. "oe", "f8e1", "d80".' },
        { icon: '📋', title: 'Read the diagnosis', body: 'See exactly what the code means, which component triggered it, and how common each cause is.' },
        { icon: '🔧', title: 'Fix it yourself', body: 'Follow the step-by-step repair guide. See which parts you need, how much they cost, and when to call a pro.' },
      ].map(item => (
        <div class="bg-gray-50 rounded-xl p-5 border border-gray-200">
          <div class="text-3xl mb-3">{item.icon}</div>
          <div class="font-bold text-gray-900 mb-2">{item.title}</div>
          <div class="text-sm text-gray-600 leading-relaxed">{item.body}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Repair cost context -->
  <section class="bg-gray-50 border-t border-gray-200 py-14">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Most Appliance Repairs Are DIY-Able — If You Know What's Wrong</h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        The average appliance repair service call costs <strong>$150–$350 for diagnosis and labor alone</strong>, before any parts. For a washing machine that needs a $25 door latch or a dryer that needs a $15 thermal fuse, that means paying $175–$375 for a 20-minute repair you could have done yourself.
      </p>
      <p class="text-gray-700 leading-relaxed mb-6">
        On the other hand, some error codes — a shorted control board, a stuck gas valve relay, a failed inverter — genuinely require professional diagnosis and tools that aren't practical to own. Every error code page on ApplianceErrors.com includes a frank <em>When to Call a Pro</em> section so you don't waste time attempting a repair beyond your skill level or risk making the problem worse.
      </p>

      <div class="grid sm:grid-cols-2 gap-4">
        {[
          { label: 'LG Dryer D80', note: 'duct blocked 80% — cleaning kit $15–$35 vs $150+ service call', diy: true },
          { label: 'Samsung Dishwasher LC', note: 'flood sensor triggered — often a $0 fix', diy: true },
          { label: 'Whirlpool Washer F8E1', note: 'water inlet valve $25–$45 vs $200 service call', diy: true },
          { label: 'Samsung Fridge 22E', note: 'ice maker fan motor $30–$70, moderate DIY', diy: true },
        ].map(item => (
          <div class="flex items-start gap-3 bg-white rounded-xl p-4 border border-gray-200">
            <span class="text-green-500 text-xl flex-shrink-0 mt-0.5">{item.diy ? '✅' : '⚠️'}</span>
            <div>
              <div class="font-semibold text-gray-900">{item.label}</div>
              <div class="text-sm text-gray-500">{item.note}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
