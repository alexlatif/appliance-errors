---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SeverityBadge from '../../../components/SeverityBadge.astro';
import BreadcrumbNav from '../../../components/BreadcrumbNav.astro';
import {
  brands, applianceTypes, getBrand, getBrandAppliances,
  getCodesByBrand, getCodesByBrandAndAppliance, getTopCodesForBrand
} from '../../../utils/data';
import { breadcrumbSchema, itemListSchema } from '../../../utils/schema';

export async function getStaticPaths() {
  return brands.map(b => ({ params: { brand: b.slug } }));
}

const { brand: brandSlug } = Astro.params;
const brand = getBrand(brandSlug!)!;
const appliances = getBrandAppliances(brandSlug!);
const topCodes = getTopCodesForBrand(brandSlug!, 9);
const allBrandCodes = getCodesByBrand(brandSlug!);

// Derived stats for content depth
const criticalCount = allBrandCodes.filter(c => c.severity === 'critical' || c.severity === 'high').length;
const applianceNames = appliances.map(a => applianceTypes.find(at=>at.slug===a)?.name ?? a);
const categoryCounts = appliances.map(a => ({
  name: applianceTypes.find(at=>at.slug===a)?.name ?? a,
  count: getCodesByBrandAndAppliance(brandSlug!, a).length,
})).filter(x=>x.count>0);

// Diagnostic system name per brand
const DIAG_NAMES: Record<string,string> = {
  samsung: 'Smart Care diagnostic system',
  lg: 'SmartDiagnosis system',
  whirlpool: 'F-code diagnostic system',
  ge: 'ERC (Electronic Range Control) diagnostic system',
  bosch: 'E-code diagnostic system',
  kitchenaid: 'F-code diagnostic platform (shared with Whirlpool)',
  frigidaire: 'F-code diagnostic system',
  maytag: 'F-code diagnostic system',
  electrolux: 'E-code diagnostic system',
  miele: 'F-code fault display system',
};

// ≤65 chars: "Whirlpool Error Codes — All Appliances | ApplianceErrors.com" = 60
const title = `${brand.name} Error Codes — All Appliances | ApplianceErrors.com`;
const description = `${brand.name} error codes for washers, dryers, dishwashers, refrigerators & ovens. Plain-English meanings and step-by-step DIY fixes. Free.`;

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Brands', url: '/brands/' },
    { name: brand.name, url: `/brands/${brandSlug}/` },
  ])
];
---

<BaseLayout {title} {description} {schemas}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <BreadcrumbNav items={[
      { label: 'Home', href: '/' },
      { label: 'Brands', href: '/brands/' },
      { label: brand.name }
    ]} />

    <!-- Brand header -->
    <div class="flex items-center gap-5 mb-8">
      <div class="w-28 h-16 flex items-center justify-center flex-shrink-0 rounded-2xl overflow-hidden border border-gray-200 bg-white p-2">
        <img src={`/logos/${brandSlug}.svg`} alt={`${brand.name} logo`}
             class="h-12 w-auto max-w-[104px] object-contain"
             onerror={`this.style.display='none';this.nextSibling.style.display='flex'`} loading="eager"/>
        <div class="w-16 h-16 rounded-2xl hidden items-center justify-center text-white text-2xl font-bold"
             style={`background-color: ${brand.logo_color}`}>{brand.name[0]}</div>
      </div>
      <div>
        <h1 class="text-3xl font-bold text-gray-900">{brand.name} Error Codes</h1>
        <p class="text-gray-600 mt-1">{brand.description}</p>
      </div>
    </div>

    <!-- Appliance type cards -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-800 mb-4">Browse by Appliance</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {appliances.map(appSlug => {
          const appType = applianceTypes.find(a => a.slug === appSlug);
          const codes = getCodesByBrandAndAppliance(brandSlug!, appSlug);
          return (
            <a href={`/brands/${brandSlug}/${appSlug}/`}
               class="group bg-white border border-gray-200 rounded-xl p-4 hover:border-brand-400 hover:shadow-md transition-all text-center">
              <div class="text-3xl mb-2">{appType?.icon ?? '🔧'}</div>
              <div class="font-semibold text-sm text-gray-800 group-hover:text-brand-600">
                {appType?.name ?? appSlug}
              </div>
              <div class="text-xs text-gray-400 mt-1">{codes.length} codes</div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Brand explainer — adds content depth for SEO -->
    <section class="mb-10 bg-gray-50 rounded-2xl p-6 border border-gray-200">
      <h2 class="text-xl font-bold text-gray-900 mb-3">About {brand.name} Error Codes</h2>
      <p class="text-gray-700 leading-relaxed mb-3">
        This database covers <strong>{allBrandCodes.length} {brand.name} error codes</strong> across
        {appliances.length} appliance {appliances.length === 1 ? 'type' : 'types'}: {applianceNames.join(', ')}.
        {criticalCount > 0 && (
          <>{criticalCount} of these codes are classified as high-severity or critical — meaning the appliance should not be run until the underlying issue is resolved.</>
        )}
      </p>
      <p class="text-gray-700 leading-relaxed mb-3">
        {brand.description}
        {DIAG_NAMES[brandSlug!] && (
          <> {brand.name} appliances use the {DIAG_NAMES[brandSlug!]} — when a fault is detected, the appliance stops operation and displays an error code on the control panel.</>
        )}
      </p>
      {categoryCounts.length > 1 && (
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mt-4">
          {categoryCounts.map(cat => (
            <a href={`/brands/${brandSlug}/${appliances[categoryCounts.indexOf(cat)]}/`}
               class="bg-white rounded-xl p-3 border border-gray-200 hover:border-brand-400 transition-colors text-center">
              <div class="font-bold text-brand-700 text-lg">{cat.count}</div>
              <div class="text-sm text-gray-600">{cat.name} codes</div>
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- Top codes grid -->
    <section>
      <h2 class="text-xl font-bold text-gray-800 mb-4">Most Common {brand.name} Error Codes</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {topCodes.map(code => (
          <a href={`/brands/${code.brand}/${code.appliance}/${code.code.toLowerCase().replace(/\s+/g,'-')}/`}
             class="group flex items-start gap-3 p-4 border border-gray-200 rounded-xl hover:border-brand-400 hover:shadow-md transition-all">
            <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center font-bold text-sm flex-shrink-0 group-hover:bg-brand-600 group-hover:text-white transition-colors">
              {code.code}
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-gray-800 group-hover:text-brand-600 capitalize">
                {code.appliance} Error {code.code}
              </div>
              <div class="text-sm text-gray-500 truncate">{code.meaning}</div>
              <div class="mt-1">
                <SeverityBadge severity={code.severity} />
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
