---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SeverityBadge from '../../../../components/SeverityBadge.astro';
import DifficultyBadge from '../../../../components/DifficultyBadge.astro';
import BreadcrumbNav from '../../../../components/BreadcrumbNav.astro';
import AdSlot from '../../../../components/AdSlot.astro';
import {
  brands, applianceTypes, getBrand, getApplianceType,
  getCodesByBrandAndAppliance
} from '../../../../utils/data';
import { breadcrumbSchema } from '../../../../utils/schema';
import proceduresData from '../../../../data/procedures.json';

export async function getStaticPaths() {
  const paths = [];
  for (const brand of brands) {
    const codes = brand.appliances;
    for (const appliance of codes) {
      paths.push({ params: { brand: brand.slug, appliance } });
    }
  }
  return paths;
}

const { brand: brandSlug, appliance: appSlug } = Astro.params;
const brand = getBrand(brandSlug!)!;
const appType = getApplianceType(appSlug!);
const codes = getCodesByBrandAndAppliance(brandSlug!, appSlug!);

// Group by severity
const bySeverity: Record<string, typeof codes> = { critical: [], high: [], medium: [], low: [] };
for (const c of codes) bySeverity[c.severity]?.push(c);

const appName = appType?.name ?? appSlug!;
const hasProcedures = (proceduresData as { procedures: { brand: string; appliance: string }[] }).procedures
  .some(p => p.brand === brandSlug && p.appliance === appSlug);
// Length-aware: long brands (e.g. "Fisher & Paykel") + "Washing Machine" overflow ~60 chars.
const _btitleFull = `${brand.name} ${appName} Error Codes — Complete List & Fixes`;
// <=56 source chars leaves headroom for &->&amp; HTML expansion the audit counts.
const title = _btitleFull.length <= 56 ? _btitleFull : `${brand.name} ${appName} Error Codes & Fixes`;
const description = `All ${brand.name} ${appName.toLowerCase()} error codes with meanings and step-by-step repair guides. ${codes.length} codes covered.`;

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Brands', url: '/brands/' },
    { name: brand.name, url: `/brands/${brandSlug}/` },
    { name: `${appName} Error Codes`, url: `/brands/${brandSlug}/${appSlug}/` },
  ])
];

// ── Unique hub overview, derived from THIS brand+appliance's real code set ──────
// Turns thin category hubs (few codes → short table) into pages with genuine,
// non-templated prose: the numbers/categories vary per page, so no two read alike.
const catCount = new Map<string, number>();
for (const c of codes) catCount.set(c.category, (catCount.get(c.category) ?? 0) + 1);
const topCats = [...catCount.entries()].sort((a, b) => b[1] - a[1]).slice(0, 3)
  .map(([cat, n]) => ({ label: cat.replace(/_/g, ' '), n }));
const catList = topCats.map(c => `${c.label} (${c.n})`).join(', ');
const diyCount = codes.filter(c => !['professional', 'expert', 'pro'].includes(c.diy_difficulty)).length;
const seriousCount = codes.filter(c => c.severity === 'critical' || c.severity === 'high').length;
const costLo = codes.length ? Math.min(...codes.map(c => c.cost_lo)) : 0;
const proHi = codes.length ? Math.max(...codes.map(c => c.pro_cost_hi)) : 0;
---

<BaseLayout {title} {description} {schemas} noindex={codes.length === 0}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <BreadcrumbNav items={[
      { label: 'Home', href: '/' },
      { label: 'Brands', href: '/brands/' },
      { label: brand.name, href: `/brands/${brandSlug}/` },
      { label: `${appName} Error Codes` }
    ]} />

    <div class="flex items-center gap-4 mb-6">
      <span class="text-5xl">{appType?.icon ?? '🔧'}</span>
      <div>
        <h1 class="text-3xl font-bold text-gray-900">{brand.name} {appName} Error Codes</h1>
        <p class="text-gray-600 mt-1">{codes.length} error codes with causes and step-by-step fixes</p>
      </div>
    </div>

    {codes.length > 0 && (
      <div class="max-w-none text-gray-700 leading-relaxed mb-8 space-y-3">
        <p>
          Your <strong>{brand.name} {appName.toLowerCase()}</strong> uses {codes.length} distinct
          error code{codes.length > 1 ? 's' : ''} to flag faults before they turn into a full
          breakdown.{topCats.length > 0 && ` The most common cluster around ${catList}.`} Of these,
          about <strong>{diyCount}</strong> can usually be cleared at home without a technician, while{' '}
          <strong>{seriousCount}</strong> point to more serious faults that may warrant a professional.
          Typical repair costs on this appliance run from <strong>${costLo}</strong> for simple DIY
          fixes up to <strong>${proHi}</strong> for professional component replacement.
        </p>
        <p>
          Find your code in the table below for its exact meaning, the most likely causes ranked by
          how often they're the culprit, a step-by-step fix, the parts you may need, and a clear
          call on when it's worth phoning a repair pro.
        </p>
        {codes.length <= 6 && (
          <p>
            Documented {brand.name} {appName.toLowerCase()} codes on this page:{' '}
            {codes.map((c, i) => (
              <>{i > 0 ? '; ' : ''}<strong class="font-mono">{c.code}</strong> — {c.meaning.toLowerCase()}</>
            ))}.
          </p>
        )}
      </div>
    )}

    {hasProcedures && (
      <div class="flex flex-wrap gap-3 mb-8">
        <a href={`/brands/${brandSlug}/${appSlug}/diagnostic-mode/`}
           class="inline-flex items-center gap-2 px-4 py-2.5 bg-brand-50 border border-brand-200 rounded-xl text-brand-700 font-medium text-sm hover:border-brand-400 hover:shadow-sm transition-all">
          🔍 How to Enter Diagnostic Mode
        </a>
        <a href={`/brands/${brandSlug}/${appSlug}/reset/`}
           class="inline-flex items-center gap-2 px-4 py-2.5 bg-brand-50 border border-brand-200 rounded-xl text-brand-700 font-medium text-sm hover:border-brand-400 hover:shadow-sm transition-all">
          🔄 How to Reset &amp; Clear Codes
        </a>
      </div>
    )}

    <!-- Quick reference table -->
    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden mb-10">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-700">Code</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-700">Meaning</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-700 hidden sm:table-cell">Severity</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-700 hidden md:table-cell">DIY</th>
              <th class="px-4 py-3 text-left font-semibold text-gray-700 hidden lg:table-cell">Est. Cost</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {codes.map(code => (
              <tr class="hover:bg-blue-50 transition-colors">
                <td class="px-4 py-3">
                  <a href={`/brands/${brandSlug}/${appSlug}/${code.code.toLowerCase().replace(/\s+/g,'-')}/`}
                     class="font-bold text-brand-600 hover:text-brand-800 font-mono">
                    {code.code}
                  </a>
                </td>
                <td class="px-4 py-3 text-gray-700">
                  <a href={`/brands/${brandSlug}/${appSlug}/${code.code.toLowerCase().replace(/\s+/g,'-')}/`}
                     class="hover:text-brand-600">
                    {code.meaning}
                  </a>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell">
                  <SeverityBadge severity={code.severity} />
                </td>
                <td class="px-4 py-3 hidden md:table-cell capitalize text-gray-600">
                  {code.diy_difficulty.replace('_', ' ')}
                </td>
                <td class="px-4 py-3 hidden lg:table-cell text-gray-600">
                  ${code.cost_lo}–${code.cost_hi}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <AdSlot placement="list" style="leaderboard" />

    <!-- High priority section -->
    {(bySeverity.critical.length + bySeverity.high.length) > 0 && (
      <section class="mb-8">
        <h2 class="text-xl font-bold text-red-700 mb-4">⚠️ Serious Errors — Act Quickly</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {[...bySeverity.critical, ...bySeverity.high].map(code => (
            <a href={`/brands/${brandSlug}/${appSlug}/${code.code.toLowerCase().replace(/\s+/g,'-')}/`}
               class="flex gap-3 p-4 bg-red-50 border border-red-200 rounded-xl hover:border-red-400 transition-all">
              <span class="font-bold text-red-700 font-mono w-14 flex-shrink-0">{code.code}</span>
              <div>
                <div class="font-medium text-gray-900">{code.meaning}</div>
                <div class="text-sm text-gray-600">{code.detail.substring(0, 80)}…</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
